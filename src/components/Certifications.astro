---
import certificationData from "@/data/certifications.json"
import LinkButton from "./LinkButton.astro"
import ExternalLink from "./icons/ExternalLink.astro"
---

<ul class="space-y-6">
  {
    certificationData.map((cert) => (
      <li class="flex gap-4 md:gap-6">
        {cert.image && (
          <div class="flex-shrink-0">
            <img
              src={cert.image}
              alt={cert.issuer}
              class="w-12 h-12 rounded-lg object-cover"
              loading="lazy"
            />
          </div>
        )}
        <div class="flex-1">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">
            {cert.title}
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">{cert.issuer}</p>
          <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">{cert.date}</p>
          {cert.link && (
            <div class="mt-3">
              <LinkButton href={cert.link}>
                <ExternalLink class="size-4" />
                Ver certificación
              </LinkButton>
            </div>
          )}
        </div>
      </li>
    ))
  }
</ul>
