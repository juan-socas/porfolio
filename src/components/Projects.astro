---
import GitHub from "./icons/GitHub.astro"
import NextJS from "./icons/NextJS.astro"
import Tailwind from "./icons/Tailwind.astro"
import ExternalLink from "./icons/ExternalLink.astro"
import Code from "./icons/Code.astro"
import AWS from "./icons/AWS.astro"
import Python from "./icons/Python.astro"
import Linux from "./icons/Linux.astro"
import Windows from "./icons/Windows.astro"
import Firewalls from "./icons/Firewalls.astro"
import Wireshark from "./icons/Wireshark.astro"
import Snort from "./icons/Snort.astro"
import Lidar from "./icons/Lidar.astro"
import ROS from "./icons/ROS.astro"
import CPlusPlus from "./icons/CPlusPlus.astro"
import Incidents from "./icons/Incidents.astro"
import LinkButton from "./LinkButton.astro"
import projectsData from "@/data/projects.json"

const TAGS: Record<string, { name: string; class: string; icon: any }> = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  AWS: {
    name: "AWS",
    class: "bg-[#FF9900] text-white",
    icon: NextJS,
  },
  PYTHON: {
    name: "Python",
    class: "bg-[#3776AB] text-white",
    icon: NextJS,
  },
  "Gestion de Incidentes": {
    name: "Gestion de Incidentes",
    class: "bg-[#DC2626] text-white",
    icon: NextJS,
  },
  LINUX: {
    name: "Linux",
    class: "bg-[#FCC624] text-black",
    icon: NextJS,
  },
  WINDOWS: {
    name: "Windows",
    class: "bg-[#0078D4] text-white",
    icon: NextJS,
  },
  FIREWALLS: {
    name: "Firewalls",
    class: "bg-[#444444] text-white",
    icon: NextJS,
  },
  WIRESHARK: {
    name: "Wireshark",
    class: "bg-[#1679A7] text-white",
    icon: NextJS,
  },
  SNORT: {
    name: "Snort",
    class: "bg-[#DC143C] text-white",
    icon: NextJS,
  },
  LIDAR: {
    name: "Lidar",
    class: "bg-[#9333EA] text-white",
    icon: NextJS,
  },
  "ROS 2": {
    name: "ROS 2",
    class: "bg-[#22D3EE] text-black",
    icon: NextJS,
  },
  "C++": {
    name: "C++",
    class: "bg-[#00599C] text-white",
    icon: NextJS,
  },
}

const PROJECTS = projectsData.map((project) => ({
  ...project,
  tags: (project.tags ?? []).map((key) => TAGS[key]).filter(Boolean),
}))
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
    <article class="flex flex-col space-x-0 space-y-6 group md:flex-row md:space-x-10 md:space-y-0">
  {image && (
    <div class="w-full md:w-1/2">
      <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition-all duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-[0_20px_60px_-10px_rgba(251,191,36,0.2)] lg:border lg:border-gray-800 lg:hover:border-yellow-400/30 lg:hover:bg-gray-800/50">
        <img alt={title} class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105" loading="lazy" src={image} />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>
      </div>
    </div>
  )}

  <div class={`w-full ${image ? 'md:w-1/2' : 'w-full'} md:max-w-lg flex flex-col justify-center`}>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      {title}
    </h3>
    <ul class="flex flex-row flex-wrap mt-3 gap-2">
      {(tags ?? []).map((tag) => tag && (
        <li>
          <span
            class={`flex gap-x-2 rounded-full text-xs ${tag.class ?? "bg-gray-200 text-gray-800 dark:bg-gray-700 dark:text-gray-200"} py-1 px-2`}
          >
            {tag.icon && <tag.icon class="size-4" />}
            {tag.name}
          </span>
        </li>
      ))}
    </ul>

    <p class="mt-3 text-gray-700 dark:text-gray-400 text-pretty">{description}</p>
    <footer class="flex items-center mt-4 gap-x-4">
      {github && (
        <LinkButton href={github}>
          <GitHub class="size-5" />
          Code
        </LinkButton>
      )}
      {link && (
        <LinkButton href={link}>
          <ExternalLink class="size-4" />
          Preview
        </LinkButton>
      )}
    </footer>
  </div>
</article>
    ))
  }
</div>



